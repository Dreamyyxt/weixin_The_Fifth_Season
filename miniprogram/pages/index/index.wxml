<!-- 首页 - 第五季 The Fifth Season -->
<view class="container">

  <!-- 顶部品牌区 -->
  <view class="hero">
    <view class="hero-logo">
      <view class="logo-circle">
        <image class="logo-img" src="/images/头像摩卡.jpg" mode="aspectFill" />
      </view>
    </view>
    <view class="hero-text">
      <text class="hero-en">The Fifth Season</text>
      <text class="hero-slogan">在春夏秋冬之外，遇见宠物、花卉与美丽</text>
    </view>
  </view>

  <!-- 轮播 Banner -->
  <swiper class="banner" autoplay="{{true}}" interval="3500" circular="{{true}}" indicator-dots="{{true}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#FFFFFF">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-item banner-{{item.theme}}">
        <view class="banner-tag">{{item.tag}}</view>
        <text class="banner-title">{{item.title}}</text>
        <text class="banner-sub">{{item.subtitle}}</text>
        <view class="banner-btn" bindtap="goBooking">立即预约</view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 快捷入口 -->
  <view class="quick-grid">
    <view class="quick-item" bindtap="goBooking">
      <view class="quick-icon q-rose">
        <text class="quick-emoji">💅</text>
      </view>
      <text class="quick-label">立即预约</text>
    </view>
    <view class="quick-item" bindtap="goShop">
      <view class="quick-icon q-gold">
        <text class="quick-emoji">🎁</text>
      </view>
      <text class="quick-label">商城</text>
    </view>
    <view class="quick-item" bindtap="goCommunity">
      <view class="quick-icon q-green">
        <text class="quick-emoji">📸</text>
      </view>
      <text class="quick-label">晒图社区</text>
    </view>
    <view class="quick-item" bindtap="goProfile">
      <view class="quick-icon q-purple">
        <text class="quick-emoji">👑</text>
      </view>
      <text class="quick-label">会员中心</text>
    </view>
  </view>

  <!-- 店员简介 -->
  <view class="section-header">
    <text class="section-title">店员简介</text>
  </view>
  <scroll-view class="staff-scroll" scroll-x="{{true}}" enhanced="{{true}}">
    <view class="staff-list">
      <view class="staff-card" wx:for="{{technicians}}" wx:key="_id"
        bindtap="openTechDetail" data-id="{{item._id}}">
        <view class="staff-avatar">
          <image wx:if="{{item.avatarIsImg}}" src="{{item.avatar}}" mode="aspectFill" class="staff-avatar-img" />
          <text wx:else class="staff-emoji">{{item.avatar}}</text>
        </view>
        <view class="staff-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
        <text class="staff-name">{{item.name}}</text>
        <text class="staff-title">{{item.title}}</text>
        <view class="staff-book-btn">查看详情</view>
      </view>
    </view>
  </scroll-view>

  <!-- 精选作品 -->
  <view class="section-header">
    <text class="section-title">精选作品</text>
    <text class="section-more" bindtap="goCommunity">查看更多 ›</text>
  </view>
  <scroll-view class="works-scroll" scroll-x="{{true}}" enhanced="{{true}}">
    <view class="works-list">
      <view class="work-card" bindtap="goCommunity">
        <view class="work-thumb work-pink"><text class="work-emoji">💅</text></view>
        <text class="work-label">日式凝胶</text>
      </view>
      <view class="work-card" bindtap="goCommunity">
        <view class="work-thumb work-coral"><text class="work-emoji">🌸</text></view>
        <text class="work-label">春日樱花</text>
      </view>
      <view class="work-card" bindtap="goCommunity">
        <view class="work-thumb work-lavender"><text class="work-emoji">💜</text></view>
        <text class="work-label">紫色渐变</text>
      </view>
      <view class="work-card" bindtap="goCommunity">
        <view class="work-thumb work-gold"><text class="work-emoji">✨</text></view>
        <text class="work-label">高定金箔</text>
      </view>
      <view class="work-card" bindtap="goCommunity">
        <view class="work-thumb work-green"><text class="work-emoji">🌿</text></view>
        <text class="work-label">清新法式</text>
      </view>
      <view class="work-card" bindtap="goCommunity">
        <view class="work-thumb work-white"><text class="work-emoji">🤍</text></view>
        <text class="work-label">简约纯色</text>
      </view>
    </view>
  </scroll-view>

  <!-- VIP 会员横幅 -->
  <view class="vip-banner" bindtap="goProfile">
    <view class="vip-deco">✦</view>
    <view class="vip-content">
      <text class="vip-title">第五季 会员俱乐部</text>
      <text class="vip-desc">专属折扣 · 积分兑礼 · VIP Room</text>
    </view>
    <text class="vip-arrow">›</text>
  </view>

  <!-- 公告滚动 -->
  <view class="notice-bar">
    <text class="notice-icon">🌸</text>
    <text class="notice-text">{{notices[noticeIndex]}}</text>
  </view>

  <!-- 关于我们 -->
  <view class="about-card">
    <view class="about-row">
      <view class="about-item">
        <text class="about-icon">🐾</text>
        <text class="about-label">宠物友好</text>
      </view>
      <view class="about-item">
        <text class="about-icon">🌺</text>
        <text class="about-label">四季花艺</text>
      </view>
      <view class="about-item">
        <text class="about-icon">🏅</text>
        <text class="about-label">高定美甲</text>
      </view>
      <view class="about-item">
        <text class="about-icon">🚪</text>
        <text class="about-label">VIP 包间</text>
      </view>
    </view>
    <view class="about-quote">
      <text class="quote-mark">"</text>
      <text class="quote-text">独属于你的 第五季</text>
      <text class="quote-mark">"</text>
    </view>
  </view>

</view>

<!-- ═══ 店员详情弹窗 ═══ -->
<view class="tech-mask" wx:if="{{showTechDetail}}" bindtap="closeTechDetail">
  <view class="tech-sheet" catchtap="noop">
    <view class="tech-sheet-handle"></view>

    <view class="tech-sheet-top">
      <view class="tech-sheet-avatar">
        <image wx:if="{{selectedTech.avatarIsImg}}" src="{{selectedTech.avatar}}" mode="aspectFill" class="tech-sheet-avatar-img" />
        <text wx:else class="tech-sheet-emoji">{{selectedTech.avatar}}</text>
      </view>
      <view class="tech-sheet-meta">
        <view class="tech-sheet-name-row">
          <text class="tech-sheet-name">{{selectedTech.name}}</text>
          <view class="tech-sheet-badge" wx:if="{{selectedTech.badge}}">{{selectedTech.badge}}</view>
        </view>
        <text class="tech-sheet-role">{{selectedTech.title}}</text>
        <text class="tech-sheet-price">起价 ¥{{selectedTech.priceFrom}}</text>
      </view>
    </view>

    <text class="tech-sheet-desc">{{selectedTech.desc}}</text>

    <view class="tech-sheet-skills">
      <view class="skill-tag" wx:for="{{selectedTech.skills}}" wx:key="*this" wx:for-item="s">{{s}}</view>
    </view>

    <view class="tech-sheet-book-btn" bindtap="goBookingFromDetail">立即预约 →</view>
  </view>
</view>
