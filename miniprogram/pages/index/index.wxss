/* 首页样式 */

/* 顶部品牌区 */
.hero {
  display: flex;
  align-items: center;
  padding: 48rpx 36rpx 32rpx;
  gap: 24rpx;
}

.logo-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8847A, #E8A89E);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(200, 132, 122, 0.35);
  flex-shrink: 0;
}

.logo-zh {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-en {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2C2C;
  letter-spacing: 1rpx;
}

.hero-slogan {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

/* Banner */
.banner {
  margin: 0 30rpx;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  height: 320rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx;
  position: relative;
}

.banner-spring {
  background: linear-gradient(135deg, #F7D9D7, #F2BEB8);
}

.banner-summer {
  background: linear-gradient(135deg, #D4E8D3, #B8D9B5);
}

.banner-vip {
  background: linear-gradient(135deg, #E8D9C8, #D4C0A0);
}

.banner-tag {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  background: rgba(255,255,255,0.9);
  color: #C8847A;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C2C2C;
  margin-bottom: 12rpx;
}

.banner-sub {
  font-size: 26rpx;
  color: #555555;
  margin-bottom: 28rpx;
}

.banner-btn {
  background: #C8847A;
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  display: inline-block;
  width: fit-content;
}

/* 快捷入口 */
.quick-grid {
  display: flex;
  padding: 32rpx 20rpx 12rpx;
  gap: 0;
}

.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.q-rose { background: #FDE8E6; }
.q-gold { background: #FDF3E3; }
.q-green { background: #E6F0E5; }
.q-purple { background: #EDE6F5; }

.quick-emoji {
  font-size: 44rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #555555;
  font-weight: 500;
}

/* 精选作品 */
.works-scroll {
  padding: 0 30rpx;
  white-space: nowrap;
}

.works-list {
  display: flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.work-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.work-thumb {
  width: 160rpx;
  height: 200rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.work-pink    { background: linear-gradient(135deg, #F9D7D4, #F2B5B0); }
.work-coral   { background: linear-gradient(135deg, #F9D5C0, #F4B898); }
.work-lavender{ background: linear-gradient(135deg, #E2D5F2, #CDB8E8); }
.work-gold    { background: linear-gradient(135deg, #F2E6C8, #E8CFA0); }
.work-green   { background: linear-gradient(135deg, #D5E8D3, #BAD5B7); }
.work-white   { background: linear-gradient(135deg, #F5F0ED, #EDE5E0); }

.work-emoji {
  font-size: 56rpx;
}

.work-label {
  font-size: 24rpx;
  color: #666666;
}

/* VIP 横幅 */
.vip-banner {
  margin: 12rpx 30rpx 24rpx;
  background: linear-gradient(135deg, #3D3228, #5A4A3C);
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.vip-deco {
  color: #C9A76B;
  font-size: 36rpx;
  flex-shrink: 0;
}

.vip-content {
  flex: 1;
}

.vip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.vip-desc {
  display: block;
  font-size: 22rpx;
  color: #C9A76B;
}

.vip-arrow {
  color: #C9A76B;
  font-size: 40rpx;
}

/* 公告 */
.notice-bar {
  margin: 0 30rpx 24rpx;
  background: #FEF8F7;
  border: 1rpx solid #F5DDD9;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.notice-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 26rpx;
  color: #C8847A;
  flex: 1;
}

/* 关于我们 */
.about-card {
  margin: 0 30rpx 40rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(200, 132, 122, 0.08);
}

.about-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.about-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.about-icon {
  font-size: 44rpx;
}

.about-label {
  font-size: 22rpx;
  color: #888888;
}

.about-quote {
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F5F0ED;
}

.quote-mark {
  font-size: 40rpx;
  color: #E8A89E;
  line-height: 1;
}

.quote-text {
  font-size: 28rpx;
  color: #888888;
  font-style: italic;
  letter-spacing: 2rpx;
}
