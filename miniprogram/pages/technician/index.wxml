<!-- 技师列表 -->
<view class="container">

  <view class="page-header">
    <text class="page-title">专属技师团队</text>
    <text class="page-sub">每一位技师都是美丽的创作者</text>
  </view>

  <view class="tech-list">
    <view class="tech-card" wx:for="{{technicians}}" wx:key="_id">

      <!-- 头部：头像 + 基本信息 -->
      <view class="tech-top">
        <view class="tech-avatar-wrap">
          <view class="tech-avatar">
            <image wx:if="{{item.avatarIsImg}}" src="{{item.avatar}}" mode="aspectFill" class="tech-avatar-img" />
            <text wx:else class="tech-emoji">{{item.avatar}}</text>
          </view>
          <view class="avail-dot avail-{{item.available === null ? 'loading' : item.available ? 'on' : 'off'}}"></view>
        </view>

        <view class="tech-info">
          <view class="tech-name-row">
            <text class="tech-name">{{item.name}}</text>
            <view class="tech-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
          </view>
          <text class="tech-title">{{item.title}}</text>
        </view>

        <view class="tech-price">
          <text class="price-from">起价</text>
          <text class="price-num">¥{{item.priceFrom}}</text>
        </view>
      </view>

      <!-- 简介 -->
      <text class="tech-desc">{{item.desc}}</text>

      <!-- 技能标签 -->
      <view class="skill-list">
        <view class="skill-tag" wx:for="{{item.skills}}" wx:key="*this" wx:for-item="skill">
          {{skill}}
        </view>
      </view>

      <!-- 预约按钮 -->
      <view class="tech-footer">
        <view wx:if="{{item.available === null}}" class="avail-label avail-text-loading">○ 查询中...</view>
        <view wx:elif="{{item.available}}" class="avail-label avail-text-on">● 今日可约</view>
        <view wx:else class="avail-label avail-text-off">○ 今天不可约</view>

        <view class="book-btn book-disabled" wx:if="{{item.available === null}}">查询中...</view>
        <view
          wx:else
          class="book-btn {{item.available ? 'book-active' : 'book-other'}}"
          bindtap="goBooking"
          data-id="{{item._id}}"
        >{{item.available ? '立即预约' : '预约其他日期'}}</view>
      </view>

    </view>
  </view>

</view>
