<!-- 登录 / 编辑资料页 -->
<view class="container">

  <!-- 顶部品牌 -->
  <view class="brand">
    <view class="brand-logo">
      <image class="brand-logo-img" src="/images/头像摩卡.jpg" mode="aspectFill" />
    </view>
    <text class="brand-slogan">在春夏秋冬之外，遇见宠物、花卉与美丽</text>
  </view>

  <!-- 卡片 -->
  <view class="form-card">
    <text class="form-title">{{isEdit ? '编辑资料' : '欢迎加入'}}</text>
    <text class="form-sub">{{isEdit ? '修改您的昵称和头像' : '使用微信信息快速完善您的资料'}}</text>

    <!-- 头像选择 -->
    <view class="avatar-section">
      <button
        class="avatar-btn"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <image
          wx:if="{{avatarUrl}}"
          class="avatar-img"
          src="{{avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-icon">📷</text>
        </view>
      </button>
      <text class="avatar-label">点击更换微信头像</text>
    </view>

    <!-- 昵称输入 -->
    <view class="input-group">
      <text class="input-label">昵称</text>
      <view class="input-wrap">
        <input
          class="nickname-input"
          type="nickname"
          placeholder="点击填写微信昵称"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">手机号</text>
      <view class="input-wrap">
        <input
          class="nickname-input"
          type="number"
          placeholder="请输入手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">性别</text>
      <view class="gender-row">
        <view
          class="gender-opt {{gender === 'female' ? 'gender-selected' : ''}}"
          bindtap="onGenderTap" data-val="female"
        >女</view>
        <view
          class="gender-opt {{gender === 'male' ? 'gender-selected' : ''}}"
          bindtap="onGenderTap" data-val="male"
        >男</view>
        <view
          class="gender-opt {{gender === '' ? 'gender-selected' : ''}}"
          bindtap="onGenderTap" data-val=""
        >不填</view>
      </view>
    </view>

    <view class="input-group">
      <view class="input-label-row">
        <text class="input-label">生日</text>
        <text class="input-label-hint">🎁 生日月享专属优惠</text>
      </view>
      <picker mode="date" value="{{birthday}}" start="1950-01-01" end="2015-12-31" bindchange="onBirthdayChange">
        <view class="input-wrap picker-row">
          <text class="{{birthday ? 'picker-val' : 'picker-placeholder'}}">{{birthday || '选择生日（可不填）'}}</text>
        </view>
      </picker>
    </view>

    <!-- 新用户提示 -->
    <view class="welcome-tips" wx:if="{{!isEdit}}">
      <view class="tip-item">
        <text class="tip-icon">🎁</text>
        <text class="tip-text">注册即送 100 积分</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">🐾</text>
        <text class="tip-text">宠物友好，欢迎携毛孩子来访</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">✦</text>
        <text class="tip-text">发帖、消费均可积累积分</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-btn" bindtap="submit">
      {{isEdit ? '保存修改' : '开始体验'}}
    </view>
  </view>

</view>
