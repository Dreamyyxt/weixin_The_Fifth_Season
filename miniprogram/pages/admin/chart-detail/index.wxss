@import '../admin-common.wxss';

.detail-page {
  background: #FAF7F4;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 时间范围 Tab */
.range-tabs {
  display: flex;
  gap: 12rpx;
  margin: 16rpx 24rpx 0;
}

.range-tab {
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #888888;
  background: #FFFFFF;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.range-active {
  background: #C8847A;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(200,132,122,0.35);
}

/* 自定义日期范围行 */
.custom-range-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 12rpx 24rpx 0;
}

.custom-date-chip {
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  font-size: 24rpx;
  color: #888888;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.05);
  white-space: nowrap;
}

.cdp-filled {
  color: #444444;
}

.custom-range-sep {
  font-size: 24rpx;
  color: #AAAAAA;
  flex-shrink: 0;
}

.custom-apply-btn {
  background: #C8847A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  flex-shrink: 0;
  margin-left: auto;
}

/* 图表卡片 */
.detail-chart-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 20rpx 16rpx;
  margin: 16rpx 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 多线图例 */
.chart-legend {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.cl-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cl-line {
  width: 28rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.cl-name {
  font-size: 22rpx;
  color: #555555;
}

.detail-canvas {
  width: 100%;
  height: 360rpx;
  display: block;
}

/* 多系列统计表格 */
.multi-stats-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.msc-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F5F0ED;
}

.msc-row:last-child {
  border-bottom: none;
}

.header-row {
  padding-bottom: 8rpx;
}

.msc-name-col {
  flex: 1.4;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.msc-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.msc-name {
  font-size: 24rpx;
  color: #444444;
  font-weight: 500;
}

.msc-col-head {
  flex: 1;
  font-size: 22rpx;
  color: #AAAAAA;
  text-align: center;
}

.msc-val {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #2C2C2C;
  text-align: center;
}

/* 单系列汇总卡片 */
.detail-stats-row {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 0;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.detail-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.detail-stat-divider {
  width: 1rpx;
  background: #F0EDEA;
  align-self: stretch;
}

.detail-stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #2C2C2C;
  line-height: 1;
}

.detail-stat-label {
  font-size: 22rpx;
  color: #AAAAAA;
}

/* 右侧占位 */
.nav-right-placeholder {
  width: 48rpx;
}
