@import '../admin-common.wxss';

.perf-page {
  background: #F0EDEA;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 导航栏中部（标题 + 日期副标题） */
.nav-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

.nav-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1;
}

.nav-right-placeholder {
  width: 60rpx;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding-top: 120rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #AAAAAA;
}

/* 汇总卡片 */
.summary-card {
  background: linear-gradient(135deg, #C8847A, #D9A09A);
  margin: 20rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(200,132,122,0.30);
}

.summary-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.summary-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.summary-total {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -1rpx;
}

.summary-breakdown {
  display: flex;
  align-items: stretch;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.summary-divider {
  width: 1rpx;
  background: rgba(255,255,255,0.25);
  margin: 4rpx 0;
}

.summary-item-val        { font-size: 30rpx; font-weight: 700; color: #FFFFFF; }
.summary-item-val-card   { color: #FFE8A3; }
.summary-item-val-muted  { color: rgba(255,255,255,0.45); }
.summary-item-label      { font-size: 20rpx; color: rgba(255,255,255,0.75); }

/* 空状态 */
.empty-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text { font-size: 28rpx; color: #AAAAAA; }

/* 技师业绩卡片 */
.tech-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 16rpx 24rpx 0;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.tc-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.tc-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F0E8E4, #E8D4CF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #C8847A;
  flex-shrink: 0;
}

.tc-info  { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.tc-name  { font-size: 30rpx; font-weight: 700; color: #2C2C2C; }
.tc-count { font-size: 22rpx; color: #AAAAAA; }
.tc-total { font-size: 36rpx; font-weight: 800; color: #C8847A; }

/* 指标网格：第一行3列，第二行2列居中 */
.tc-grid {
  display: flex;
  flex-wrap: wrap;
  background: #F5F0ED;
  border-radius: 16rpx;
  overflow: hidden;
}

.tc-metric {
  width: 33.333%;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.tc-metric:nth-child(4),
.tc-metric:nth-child(5) {
  width: 50%;
  border-top: 1rpx solid #EDE6E2;
}

.tc-metric-val   { font-size: 30rpx; font-weight: 700; color: #2C2C2C; }
.tc-metric-card  { color: #C9A76B; }
.tc-metric-muted { color: #CCCCCC; font-weight: 400; }
.tc-metric-label { font-size: 20rpx; color: #AAAAAA; }

/* 底部说明 */
.footnote {
  margin: 20rpx 24rpx 0;
  font-size: 22rpx;
  color: #BBBBBB;
  line-height: 1.6;
  text-align: center;
  padding: 0 16rpx;
}
