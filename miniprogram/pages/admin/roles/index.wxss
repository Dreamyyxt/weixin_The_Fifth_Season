@import '../admin-common.wxss';

.tip-box {
  background: #FFF8E7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
  border-left: 6rpx solid #F5A623;
}
.tip-title { display: block; font-size: 24rpx; font-weight: 600; color: #7A5C00; margin-bottom: 8rpx; }
.tip-text  { font-size: 22rpx; color: #7A5C00; line-height: 1.6; }

.field-hint { display: block; font-size: 22rpx; color: #AAAAAA; margin-top: 8rpx; }

.lookup-btn {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #2980B9;
  text-align: center;
  padding: 14rpx 0;
  border: 1rpx dashed #ADD4EE;
  border-radius: 12rpx;
  background: #F0F7FB;
}

.action-btn { text-align: center; display: block; }

.unlink-btn {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #C0392B;
  text-align: center;
  padding: 14rpx 0;
  border: 1rpx dashed #E0B0AA;
  border-radius: 12rpx;
}

.unlink-hint-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FEF0EE;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #C0392B;
}

.unlink-hint-text {
  font-size: 26rpx;
  color: #C0392B;
  flex: 1;
}

.unlink-undo {
  font-size: 24rpx;
  color: #888888;
  margin-left: 20rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid #DDDDDD;
  border-radius: 20rpx;
}
