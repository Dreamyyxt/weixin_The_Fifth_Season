@import '../admin-common.wxss';

.pkg-tabs {
  display: flex;
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.p-tab { flex: 1; text-align: center; padding: 18rpx 0; font-size: 26rpx; color: #888888; border-radius: 12rpx; }
.p-tab-active { background: #C8847A; color: #FFFFFF; font-weight: 600; }

.pkg-item { margin-bottom: 16rpx; }
.pi-top { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 16rpx; }
.pi-img { width: 80rpx; height: 80rpx; border-radius: 12rpx; flex-shrink: 0; }
.pi-img-placeholder { width: 80rpx; height: 80rpx; border-radius: 12rpx; background: #F0EDEA; flex-shrink: 0; }
.pi-info { flex: 1; }
.pi-name  { display: block; font-size: 28rpx; font-weight: 600; color: #2C2C2C; margin-bottom: 4rpx; }
.pi-desc  { display: block; font-size: 22rpx; color: #AAAAAA; margin-bottom: 4rpx; }
.pi-price { display: block; font-size: 24rpx; color: #C8847A; font-weight: 600; }
.pi-pts   { display: block; font-size: 24rpx; color: #C9A76B; font-weight: 600; }
.pi-tag   { font-size: 20rpx; color: #C8847A; background: #FDE8E6; padding: 4rpx 14rpx; border-radius: 12rpx; flex-shrink: 0; }
.pi-tag-gold { color: #C9A76B; background: #FDF5E0; }
.pi-tag-vip  { color: #7B4FA6; background: #F0EBF8; }
