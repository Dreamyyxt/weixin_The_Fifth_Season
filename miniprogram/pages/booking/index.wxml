<!-- 预约页 -->
<view class="container">

  <!-- 进度步骤 -->
  <view class="steps">
    <view class="step {{step >= 1 ? 'step-active' : ''}}">
      <view class="step-num">1</view>
      <text class="step-label">选择服务</text>
    </view>
    <view class="step-line"></view>
    <view class="step {{step >= 2 ? 'step-active' : ''}}">
      <view class="step-num">2</view>
      <text class="step-label">填写信息</text>
    </view>
  </view>

  <!-- 技师信息卡 -->
  <view class="tech-card" wx:if="{{tech}}">
    <view class="tech-avatar-sm">
      <image wx:if="{{tech.avatarIsImg}}" src="{{tech.avatar}}" mode="aspectFill" class="tech-avatar-sm-img" />
      <text wx:else>{{tech.avatar}}</text>
    </view>
    <view class="tech-meta">
      <text class="tech-name">{{tech.name}}</text>
      <text class="tech-title">{{tech.title}}</text>
    </view>
    <view class="tech-badge-sm">已选技师</view>
  </view>

  <!-- STEP 1: 选择服务 / 日期 / 时间 -->
  <block wx:if="{{step === 1}}">

    <!-- 服务项目 -->
    <view class="section-header">
      <text class="section-title">选择服务</text>
    </view>

    <!-- 专属套餐（来自商城） -->
    <block wx:if="{{techPackages.length > 0}}">
      <view class="service-sub-label">
        <text class="sub-label-dot">▍</text>
        <text class="sub-label-text">专属套餐</text>
        <text class="sub-label-hint">商城套餐，直接选用</text>
      </view>
      <scroll-view class="pkg-scroll" scroll-x enable-flex>
        <view class="pkg-scroll-inner">
          <view
            class="pkg-mini-card {{selectedService && selectedService._pkgId === item._id ? 'pkg-mini-selected' : ''}}"
            wx:for="{{techPackages}}"
            wx:key="_id"
            bindtap="selectPackage"
            data-pkg="{{item}}"
          >
            <text class="pkg-mini-emoji">{{item.emoji}}</text>
            <text class="pkg-mini-name">{{item.name}}</text>
            <text class="pkg-mini-price">¥{{item.price}}</text>
            <text class="pkg-mini-dur">{{item.duration}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="service-sub-label" style="margin-top:24rpx;">
        <text class="sub-label-dot">▍</text>
        <text class="sub-label-text">单项服务</text>
      </view>
    </block>

    <view class="service-list">
      <view
        class="service-item {{selectedService && selectedService.id === item.id && !selectedService._pkgId ? 'service-selected' : ''}}"
        wx:for="{{services}}"
        wx:key="id"
        bindtap="selectService"
        data-service="{{item}}"
      >
        <view class="service-left">
          <text class="service-name">{{item.name}}</text>
          <text class="service-duration">时长 {{item.duration}}</text>
        </view>
        <view class="service-right">
          <view class="service-price-wrap">
            <text class="service-price">¥{{item.price}}</text>
            <text class="service-price-discount" wx:if="{{userDiscount < 1}}">{{userDiscountText}}</text>
          </view>
          <view class="service-check" wx:if="{{selectedService && selectedService.id === item.id && !selectedService._pkgId}}">✓</view>
        </view>
      </view>
    </view>

    <!-- VIP 提前预约提示（钻石会员不受限制） -->
    <view class="vip-notice" wx:if="{{selectedService && selectedService.id === 6 && !userPerks.noVipAdvanceLimit}}">
      <text>📌 VIP 高定全套需提前 3 天预约，日期已自动调整</text>
    </view>
    <view class="vip-notice vip-notice-perk" wx:if="{{selectedService && selectedService.id === 6 && userPerks.noVipAdvanceLimit}}">
      <text>💎 钻石会员专属：无需提前预约</text>
    </view>

    <!-- 选择日期 -->
    <view class="section-header">
      <text class="section-title">选择日期</text>
    </view>
    <view class="form-card">
      <picker mode="date" value="{{selectedDate}}" start="{{minDate}}" bindchange="onDateChange">
        <view class="picker-row">
          <text class="picker-label">预约日期</text>
          <text class="picker-value">{{selectedDate}} ›</text>
        </view>
      </picker>
    </view>

    <!-- 选择时间 -->
    <view class="section-header">
      <text class="section-title">选择时间</text>
      <text class="section-hint" wx:if="{{loadingSlots}}">加载中...</text>
      <text class="section-hint" wx:elif="{{selectedService}}">需要 {{selectedService.duration}}</text>
    </view>
    <view class="time-grid">
      <view
        class="time-slot {{item.disabled ? 'time-disabled' : ''}} {{selectedTime === item.time ? 'time-selected' : ''}}"
        wx:for="{{timeSlots}}"
        wx:key="time"
        wx:for-item="item"
        bindtap="selectTime"
        data-timeinfo="{{item}}"
      >
        {{item.time}}
        <text wx:if="{{item.booked}}" class="time-booked-tag">已约</text>
        <text wx:elif="{{item.past}}" class="time-past-tag">已过</text>
        <text wx:elif="{{item.disabled}}" class="time-insuf-tag">不足</text>
      </view>
    </view>

    <view class="submit-wrap">
      <view class="btn-primary" bindtap="nextStep">下一步</view>
    </view>

  </block>

  <!-- STEP 2: 填写联系信息 -->
  <block wx:if="{{step === 2}}">

    <!-- 预约摘要 -->
    <view class="summary-card">
      <view class="summary-title">预约摘要</view>
      <view class="summary-row">
        <text class="summary-label">服务项目</text>
        <text class="summary-value">{{selectedService.name}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">预约时间</text>
        <text class="summary-value">{{selectedDate}} {{selectedTime}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">服务时长</text>
        <text class="summary-value">{{selectedService.duration}}</text>
      </view>
      <view class="summary-row summary-price-row">
        <text class="summary-label">参考价格</text>
        <view class="summary-price-group">
          <text class="summary-price">¥{{selectedService.price}}</text>
          <text class="summary-price-tag" wx:if="{{userDiscount < 1}}">{{userDiscountText}}会员</text>
        </view>
      </view>
      <view class="summary-discount-note" wx:if="{{userDiscount < 1}}">
        <text>💡 你享有{{userDiscountText}}会员折扣，最终价格由技师服务完成后确认</text>
      </view>
      <!-- 定金提示 -->
      <view class="deposit-notice" wx:if="{{depositRequired}}">
        <text class="deposit-notice-icon">💰</text>
        <view class="deposit-notice-body">
          <text class="deposit-notice-title">需支付定金 ¥{{depositAmount}}</text>
          <text class="deposit-notice-desc">技师确认前可全额退还；确认后取消定金不退</text>
        </view>
      </view>
    </view>

    <!-- 联系信息 -->
    <view class="section-header">
      <text class="section-title">联系信息</text>
    </view>
    <view class="form-card">
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input
          class="form-input"
          placeholder="请输入您的姓名"
          value="{{name}}"
          bindinput="onNameInput"
        />
      </view>
      <view class="form-divider"></view>
      <view class="form-row">
        <text class="form-label">手机号</text>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>
      <view class="form-divider"></view>
      <view class="form-row form-row-column">
        <text class="form-label">备注</text>
        <textarea
          class="form-textarea"
          placeholder="可以告诉我们您的想法、款式偏好或携带宠物..."
          value="{{remark}}"
          bindinput="onRemarkInput"
          maxlength="200"
        />
      </view>
    </view>

    <!-- 宠物提示 -->
    <view class="pet-tip">
      <text class="pet-icon">🐾</text>
      <text class="pet-text">本店宠物友好，欢迎携带您的毛孩子！</text>
    </view>

    <view class="btn-group">
      <view class="btn-back" bindtap="prevStep">返回修改</view>
      <view class="btn-primary btn-submit" bindtap="submitBooking">确认预约</view>
    </view>

  </block>

</view>
