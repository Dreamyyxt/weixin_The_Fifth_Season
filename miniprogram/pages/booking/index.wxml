<!-- 预约页 -->
<view class="container">

  <!-- 进度步骤 -->
  <view class="steps">
    <view class="step {{step >= 1 ? 'step-active' : ''}}">
      <view class="step-num">1</view>
      <text class="step-label">{{quoteMode ? '选择时间' : '选择服务'}}</text>
    </view>
    <view class="step-line"></view>
    <view class="step {{step >= 2 ? 'step-active' : ''}}">
      <view class="step-num">2</view>
      <text class="step-label">填写信息</text>
    </view>
  </view>

  <!-- 技师信息卡（点击可换技师）-->
  <view class="tech-card" bindtap="openTechPicker">
    <view class="tech-avatar-sm">
      <block wx:if="{{tech}}">
        <image wx:if="{{tech.avatarIsImg}}" src="{{tech.avatar}}" mode="aspectFill" class="tech-avatar-sm-img" />
        <text wx:else>{{tech.avatar}}</text>
      </block>
      <text wx:else class="tech-no-select">?</text>
    </view>
    <view class="tech-meta">
      <text class="tech-name {{!tech ? 'tech-name-empty' : ''}}">{{tech ? tech.name : '请选择技师'}}</text>
      <text class="tech-title">{{tech ? tech.title : '点此选择可预约的技师'}}</text>
    </view>
    <view class="tech-badge-sm">{{tech ? '换技师' : '选择 ›'}}</view>
  </view>

  <!-- STEP 1: 选择服务 / 日期 / 时间 -->
  <block wx:if="{{step === 1}}">

    <!-- ── 报价模式：展示报价摘要，不选服务 ── -->
    <block wx:if="{{quoteMode && quoteInfo}}">
      <view class="quote-mode-card">
        <view class="qmc-header">
          <text class="qmc-badge">报价预约</text>
          <text class="qmc-price">¥{{quoteInfo.price}}</text>
        </view>
        <text class="qmc-service">{{quoteInfo.serviceName}}</text>
        <text class="qmc-duration">预计时长 {{totalDuration}}</text>
        <text class="qmc-note" wx:if="{{quoteInfo.adminNote}}">技师备注：{{quoteInfo.adminNote}}</text>
      </view>
    </block>

    <!-- ── 普通模式：选择服务 ── -->
    <block wx:else>
      <view class="section-header">
        <text class="section-title">选择服务</text>
        <text class="section-hint">可多选，时长和价格自动合计</text>
      </view>

      <!-- 专属套餐（来自商城） -->
      <block wx:if="{{techPackages.length > 0}}">
        <view class="service-sub-label">
          <text class="sub-label-dot">▍</text>
          <text class="sub-label-text">专属套餐</text>
          <text class="sub-label-hint">商城套餐，直接选用</text>
        </view>
        <scroll-view class="pkg-scroll" scroll-x enable-flex>
          <view class="pkg-scroll-inner">
            <view
              class="pkg-mini-card {{selectedPackageId === item._id ? 'pkg-mini-selected' : ''}}"
              wx:for="{{techPackages}}"
              wx:key="_id"
              bindtap="selectPackage"
              data-pkg="{{item}}"
            >
              <text class="pkg-mini-emoji">{{item.emoji}}</text>
              <text class="pkg-mini-name">{{item.name}}</text>
              <text class="pkg-mini-price">¥{{item.price}}</text>
              <text class="pkg-mini-dur">{{item.duration}}</text>
            </view>
          </view>
        </scroll-view>
        <view class="service-sub-label" style="margin-top:24rpx;">
          <text class="sub-label-dot">▍</text>
          <text class="sub-label-text">单项服务</text>
          <text class="sub-label-hint">可叠加多选</text>
        </view>
      </block>

      <view class="section-loading" wx:if="{{servicesLoading}}">加载服务项目中...</view>
      <view class="service-list" wx:elif="{{categories.length === 0}}">
        <view class="service-empty">暂无可用服务项目</view>
      </view>

      <!-- 两列服务选择器 -->
      <view class="svc-picker" wx:else>
        <!-- 左：大类列表 -->
        <scroll-view class="svc-cat-scroll" scroll-y>
          <view
            wx:for="{{categories}}" wx:key="_id"
            class="svc-cat-item {{selectedCategoryId === item._id ? 'svc-cat-active' : ''}}"
            bindtap="selectCategory"
            data-id="{{item._id}}"
          >
            <text class="svc-cat-name">{{item.name}}</text>
            <view class="svc-cat-dot" wx:if="{{selectedCategoryServiceCount[item._id] > 0}}">{{selectedCategoryServiceCount[item._id]}}</view>
          </view>
        </scroll-view>

        <!-- 右：该大类下的服务项（按子分组渲染） -->
        <scroll-view class="svc-item-scroll" scroll-y>
          <view wx:if="{{displayServiceGroups.length === 0}}" class="svc-empty-cat">暂无服务项目</view>
          <block wx:for="{{displayServiceGroups}}" wx:key="subgroup" wx:for-item="group">
            <view class="svc-subgroup-label" wx:if="{{group.subgroup}}">{{group.subgroup}}</view>
            <view
              wx:for="{{group.services}}" wx:key="_id"
              class="svc-item {{selectedServiceIds[item._id] ? 'svc-item-selected' : ''}}"
              bindtap="selectService"
              data-service="{{item}}"
            >
              <view class="svc-item-top">
                <text class="svc-item-name">{{item.name}}</text>
                <text class="svc-item-quote-tag" wx:if="{{item.isQuote}}">报价制</text>
              </view>
              <view class="svc-item-bottom">
                <text class="svc-item-dur">{{item.durationMin}}分钟</text>
                <text class="svc-item-price">¥{{item.price}}{{item.isQuote ? '起' : ''}}</text>
                <view class="svc-item-check" wx:if="{{selectedServiceIds[item._id]}}">✓</view>
              </view>
            </view>
          </block>
        </scroll-view>
      </view>

      <!-- 已选合计栏 -->
      <view class="selected-summary" wx:if="{{selectedServices.length > 0}}">
        <view class="sel-sum-left">
          <text class="sel-sum-count">已选 {{selectedServices.length}} 项</text>
          <text class="sel-sum-detail">{{totalDuration}}</text>
        </view>
        <text class="sel-sum-price">参考 ¥{{totalPrice}}</text>
      </view>

      <!-- VIP 提前预约提示 -->
      <view class="vip-notice" wx:if="{{hasVipService && !userPerks.noVipAdvanceLimit}}">
        <text>📌 VIP 高定全套需提前 3 天预约，日期已自动调整</text>
      </view>
      <view class="vip-notice vip-notice-perk" wx:if="{{hasVipService && userPerks.noVipAdvanceLimit}}">
        <text>💎 钻石会员专属：无需提前预约</text>
      </view>
    </block>

    <!-- 选择日期 -->
    <view class="section-header">
      <text class="section-title">选择日期</text>
    </view>
    <view class="form-card">
      <picker mode="date" value="{{selectedDate}}" start="{{minDate}}" bindchange="onDateChange">
        <view class="picker-row">
          <text class="picker-label">预约日期</text>
          <text class="picker-value">{{selectedDate}} ›</text>
        </view>
      </picker>
    </view>

    <!-- 选择时间 -->
    <view class="section-header">
      <text class="section-title">选择时间</text>
      <text class="section-hint" wx:if="{{loadingSlots}}">加载中...</text>
      <text class="section-hint" wx:elif="{{totalDuration}}">需要 {{totalDuration}}</text>
    </view>
    <view class="schedule-off-notice" wx:if="{{scheduleOff}}">
      <text class="schedule-off-text">技师当天休息，请选择其他日期</text>
    </view>

    <view class="time-grid" wx:if="{{!scheduleOff}}">
      <view
        class="time-slot {{item.disabled ? 'time-disabled' : ''}} {{selectedTime === item.time ? 'time-selected' : ''}}"
        wx:for="{{timeSlots}}"
        wx:key="time"
        wx:for-item="item"
        bindtap="selectTime"
        data-timeinfo="{{item}}"
      >
        {{item.time}}
        <text wx:if="{{item.booked}}" class="time-booked-tag">已约</text>
        <text wx:elif="{{item.past}}" class="time-past-tag">已过</text>
        <text wx:elif="{{item.disabled}}" class="time-insuf-tag">不足</text>
      </view>
    </view>

    <view class="submit-wrap">
      <view class="btn-primary" bindtap="nextStep">下一步</view>
    </view>

  </block>

  <!-- STEP 2: 填写联系信息 -->
  <block wx:if="{{step === 2}}">

    <!-- 预约摘要 -->
    <view class="summary-card">
      <view class="summary-title">预约摘要</view>

      <!-- 服务项目 -->
      <view class="summary-row summary-services-row" wx:if="{{quoteMode && quoteInfo}}">
        <text class="summary-label">服务项目</text>
        <text class="summary-value">{{quoteInfo.serviceName}}</text>
      </view>
      <view class="summary-row summary-services-row" wx:else>
        <text class="summary-label">服务项目</text>
        <view class="summary-services-col">
          <view class="summary-service-item" wx:for="{{selectedServices}}" wx:key="id">
            <text class="summary-service-name">{{item.name}}</text>
            <text class="summary-service-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>

      <view class="summary-row">
        <text class="summary-label">预约时间</text>
        <text class="summary-value">{{selectedDate}} {{selectedTime}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">合计时长</text>
        <text class="summary-value">{{totalDuration}}</text>
      </view>
      <view class="summary-row summary-price-row">
        <text class="summary-label">参考总价</text>
        <view class="summary-price-group">
          <text class="summary-price">¥{{totalPrice}}</text>
          <text class="summary-price-tag" wx:if="{{userDiscount < 1}}">{{userDiscountText}}会员</text>
        </view>
      </view>
      <view class="summary-discount-note" wx:if="{{userDiscount < 1}}">
        <text>💡 你享有{{userDiscountText}}会员折扣，最终价格由技师服务完成后确认</text>
      </view>
      <!-- 定金提示 -->
      <view class="deposit-notice" wx:if="{{depositRequired}}">
        <text class="deposit-notice-icon">💰</text>
        <view class="deposit-notice-body">
          <text class="deposit-notice-title">需支付定金 ¥{{depositAmount}}</text>
          <text class="deposit-notice-desc">技师确认前可全额退还；确认后取消定金不退</text>
        </view>
      </view>
    </view>

    <!-- 联系信息 -->
    <view class="section-header">
      <text class="section-title">联系信息</text>
    </view>
    <view class="form-card">
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input
          class="form-input"
          placeholder="请输入您的姓名"
          value="{{name}}"
          bindinput="onNameInput"
        />
      </view>
      <view class="form-divider"></view>
      <view class="form-row">
        <text class="form-label">手机号</text>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>
      <view class="form-divider"></view>
      <view class="form-row form-row-column">
        <text class="form-label">备注</text>
        <textarea
          class="form-textarea"
          placeholder="可以告诉我们您的想法、款式偏好或携带宠物..."
          value="{{remark}}"
          bindinput="onRemarkInput"
          maxlength="200"
        />
      </view>
    </view>

    <!-- 宠物提示 -->
    <view class="pet-tip">
      <text class="pet-icon">🐾</text>
      <text class="pet-text">本店宠物友好，欢迎携带您的毛孩子！</text>
    </view>

    <view class="btn-group">
      <view class="btn-back" bindtap="prevStep">返回修改</view>
      <view class="btn-primary btn-submit" bindtap="submitBooking">确认预约</view>
    </view>

  </block>

</view>

<!-- 技师选择弹窗 -->
<view class="tech-pick-mask" wx:if="{{showTechPicker}}" bindtap="closeTechPicker">
  <view class="tech-pick-sheet" catchtap="noop">
    <view class="tech-pick-handle"></view>
    <text class="tech-pick-title">选择技师</text>
    <text class="tech-pick-hint" wx:if="{{availableTechs.length < technicians.length}}">以下技师可提供所选服务</text>
    <view class="tech-pick-list">
      <view
        class="tech-pick-item {{techId === item._id ? 'tech-pick-sel' : ''}}"
        wx:for="{{availableTechs}}"
        wx:key="_id"
        wx:for-item="item"
        bindtap="changeTech"
        data-tech="{{item}}"
      >
        <view class="tech-pick-avatar">
          <image wx:if="{{item.avatarIsImg}}" src="{{item.avatar}}" mode="aspectFill" class="tech-pick-avatar-img" />
          <text wx:else class="tech-pick-emoji">{{item.avatar}}</text>
        </view>
        <view class="tech-pick-info">
          <text class="tech-pick-name">{{item.name}}</text>
          <text class="tech-pick-role">{{item.title}} · 起价 ¥{{item.priceFrom}}</text>
        </view>
        <text class="tech-pick-check" wx:if="{{techId === item._id}}">✓</text>
      </view>
    </view>
  </view>
</view>

<!-- 定金支付方式弹窗 -->
<view class="pm-mask" wx:if="{{showDepositModal}}" bindtap="cancelDepositModal">
  <view class="pm-card" catchtap>
    <view class="pm-title">支付定金</view>
    <view class="pm-amount-hint">定金金额：¥{{depositAmount}}</view>

    <view
      class="pm-option {{depositPayMethod === 'balance' ? 'pm-opt-selected' : ''}} {{!depBalanceSufficient ? 'pm-opt-disabled' : ''}}"
      bindtap="selectDepositPayMethod" data-method="balance"
    >
      <view class="pm-opt-left">
        <text class="pm-opt-icon">💳</text>
        <view class="pm-opt-info">
          <text class="pm-opt-name">余额支付</text>
          <text class="pm-opt-sub {{!depBalanceSufficient ? 'pm-sub-warn' : ''}}">当前余额 ¥{{userBalance}}{{!depBalanceSufficient ? '（余额不足）' : ''}}</text>
        </view>
      </view>
      <view class="pm-opt-check" wx:if="{{depositPayMethod === 'balance'}}">✓</view>
    </view>

    <view
      class="pm-option {{depositPayMethod === 'wechat' ? 'pm-opt-selected' : ''}}"
      bindtap="selectDepositPayMethod" data-method="wechat"
    >
      <view class="pm-opt-left">
        <text class="pm-opt-icon">💚</text>
        <view class="pm-opt-info">
          <text class="pm-opt-name">微信支付</text>
        </view>
      </view>
      <view class="pm-opt-check" wx:if="{{depositPayMethod === 'wechat'}}">✓</view>
    </view>

    <view class="pm-btns">
      <view class="pm-btn pm-btn-cancel" bindtap="cancelDepositModal">稍后支付</view>
      <view class="pm-btn pm-btn-confirm" bindtap="confirmDepositPay">确认支付</view>
    </view>
  </view>
</view>
