<!-- 个人信息页 -->
<view class="container">

  <!-- 会员卡 -->
  <view class="member-card">
    <view class="member-top">
      <!-- 头像：有微信头像则显示图片，否则显示首字母 -->
      <view class="member-avatar">
        <image
          wx:if="{{userInfo.avatarUrl}}"
          class="avatar-img"
          src="{{userInfo.avatarUrl}}"
          mode="aspectFill"
        />
        <text wx:else class="avatar-text">{{userInfo.nickname ? userInfo.nickname[0] : '我'}}</text>
      </view>
      <view class="member-info">
        <text class="member-name">{{userInfo.nickname || '点击设置昵称'}}</text>
        <view class="vip-level-badge">
          <text class="vip-star">✦</text>
          <text class="vip-level">{{userInfo.vipLevel || '普通会员'}}</text>
        </view>
      </view>
      <view class="member-edit" bindtap="goEdit">编辑</view>
    </view>

    <!-- 数据栏 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{userInfo.points}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">¥{{userInfo.balance}}</text>
        <text class="stat-label">余额</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">3</text>
        <text class="stat-label">预约次数</text>
      </view>
    </view>

    <!-- 快捷按钮 -->
    <view class="quick-btns">
      <view class="quick-btn-item" bindtap="showRecharge">
        <text class="qb-icon">💳</text>
        <text class="qb-label">充值</text>
      </view>
      <view class="quick-btn-item" bindtap="switchSection" data-sec="booking">
        <text class="qb-icon">📋</text>
        <text class="qb-label">预约记录</text>
      </view>
      <view class="quick-btn-item" bindtap="switchSection" data-sec="points">
        <text class="qb-icon">✦</text>
        <text class="qb-label">积分明细</text>
      </view>
    </view>
  </view>

  <!-- 内容切换 Tab -->
  <view class="content-tabs">
    <view
      class="content-tab {{activeSection === 'booking' ? 'ct-active' : ''}}"
      bindtap="switchSection"
      data-sec="booking"
    >预约记录</view>
    <view
      class="content-tab {{activeSection === 'points' ? 'ct-active' : ''}}"
      bindtap="switchSection"
      data-sec="points"
    >积分明细</view>
  </view>

  <!-- 预约记录 -->
  <view wx:if="{{activeSection === 'booking'}}">
    <view class="record-card" wx:for="{{bookingRecords}}" wx:key="id">
      <view class="record-top">
        <view class="record-service">
          <text class="record-name">{{item.service}}</text>
          <text class="record-tech">技师：{{item.tech}}</text>
        </view>
        <view class="record-status status-{{item.status}}">{{item.statusLabel}}</view>
      </view>
      <view class="record-bottom">
        <text class="record-time">{{item.date}} {{item.time}}</text>
        <text class="record-price">¥{{item.price}}</text>
      </view>
      <view class="record-duration" wx:if="{{item.duration}}">
        <text class="duration-label">时长：</text>
        <text class="duration-value">{{item.duration}}</text>
      </view>
      <view class="record-remark" wx:if="{{item.remark}}">
        <text class="remark-label">备注：</text>
        <text class="remark-value">{{item.remark}}</text>
      </view>
      <view class="record-actions" wx:if="{{item.status === 'pending' || item.status === 'today'}}">
        <view class="btn-cancel" bindtap="cancelBooking" data-id="{{item.id}}">取消预约</view>
      </view>
    </view>
    
    <!-- 空状态提示 -->
    <view class="empty-state" wx:if="{{bookingRecords.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无预约记录</text>
    </view>
  </view>

  <!-- 积分明细 -->
  <view wx:if="{{activeSection === 'points'}}">
    <view class="points-log-card" wx:for="{{pointsLogs}}" wx:key="id">
      <view class="log-left">
        <view class="log-dot log-{{item.type}}"></view>
        <view class="log-info">
          <text class="log-desc">{{item.desc}}</text>
          <text class="log-time">{{item.time}}</text>
        </view>
      </view>
      <text class="log-points log-pts-{{item.type}}">{{item.points}}</text>
    </view>
  </view>

</view>
