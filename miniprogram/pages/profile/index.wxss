/* 个人信息页样式 */

/* 管理后台入口 */
.admin-entry-btn {
  margin: 0 30rpx 24rpx;
  background: linear-gradient(135deg, #2C2420, #4A3830);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

/* 管理员兼技师：两个入口并排 */
.admin-entry-group {
  margin: 0 30rpx 24rpx;
  display: flex;
  gap: 16rpx;
}

.admin-entry-half {
  flex: 1;
  margin: 0;   /* 覆盖 admin-entry-btn 的 margin，由父级 group 统一控制 */
}

.admin-entry-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.admin-entry-text {
  flex: 1;
}

.admin-entry-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.admin-entry-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.admin-entry-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 会员卡 */
.member-card {
  margin: 24rpx 30rpx;
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: background 0.4s;
  position: relative;
  overflow: hidden;
}

.card-watermark {
  position: absolute;
  top: 1%;
  left: 55%;
  width: 40%;
  height: 40%;
  opacity: 0.28;
  filter: brightness(10);
  pointer-events: none;
}

.member-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8847A, #E8A89E);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 3rpx solid rgba(201, 167, 107, 0.4);
}

.avatar-text {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.member-info {
  flex: 1;
}

.member-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.vip-level-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(201, 167, 107, 0.2);
  border: 1rpx solid rgba(201, 167, 107, 0.4);
  border-radius: 16rpx;
  padding: 5rpx 16rpx;
}

.vip-star {
  color: #C9A76B;
  font-size: 20rpx;
}

.vip-level {
  font-size: 22rpx;
  color: #C9A76B;
}

.member-edit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

/* 升级进度条 */
.tier-progress-wrap {
  margin: 24rpx 0 28rpx;
}

.tier-progress-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.tier-label-current,
.tier-label-next {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
}

.tier-label-next {
  text-align: right;
}

.tier-progress-track {
  height: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 8rpx;
  overflow: hidden;
}

.tier-progress-fill {
  height: 100%;
  background: rgba(255,255,255,0.85);
  border-radius: 8rpx;
  transition: width 0.4s ease;
}

.tier-progress-hint {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 8rpx;
  text-align: center;
}

.tier-max-wrap {
  margin: 16rpx 0 24rpx;
  text-align: center;
}

.tier-max-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* 数据栏 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 0;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

.stat-divider {
  width: 1rpx;
  background: rgba(255,255,255,0.15);
}

/* 快捷按钮 */
.quick-btns {
  display: flex;
  justify-content: space-around;
}

.quick-btn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.qb-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.qb-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* 内容 Tab */
.content-tabs {
  display: flex;
  margin: 0 30rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(200, 132, 122, 0.06);
}

.content-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #888888;
  font-weight: 500;
  border-radius: 16rpx;
}

.ct-active {
  background: #FDE8E6;
  color: #C8847A;
  font-weight: 600;
}

/* 预约记录 */
.record-card {
  margin: 0 30rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(200, 132, 122, 0.06);
  position: relative;
  overflow: hidden;
}

/* 印章水印（已取消） */
.cancelled-stamp {
  position: absolute;
  top: 50%;
  right: 32rpx;
  transform: translateY(-50%) rotate(-18deg);
  border-radius: 12rpx;
  padding: 10rpx 24rpx;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  pointer-events: none;
  white-space: nowrap;
  border: 10rpx solid rgba(180, 180, 180, 0.55);
  color: rgba(180, 180, 180, 0.55);
}


.record-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.record-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2C;
  margin-bottom: 6rpx;
}

.record-tech {
  font-size: 22rpx;
  color: #888888;
}

.record-status {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.status-done {
  background: #E6F0E5;
  color: #8DAB87;
}

.status-pending {
  background: #FDE8E6;
  color: #C8847A;
}

.status-cancelled {
  background: #F5F5F5;
  color: #AAAAAA;
}

.record-bottom {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.record-bottom-spread {
  justify-content: space-between;
  align-items: flex-end;
}

.record-datetime {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 16rpx 0 12rpx;
  border-top: 1rpx solid #F5F0ED;
}

.record-date {
  font-size: 32rpx;
  font-weight: 700;
  color: #C8847A;
}

.record-time-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #C8847A;
}

.record-time {
  font-size: 24rpx;
  color: #AAAAAA;
}

.record-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #C8847A;
}

.record-quote-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-quote-dur {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C2C2C;
}

.record-quote-tech {
  font-size: 22rpx;
  color: #888888;
}

.record-duration {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #F5F0ED;
}

.duration-label {
  font-size: 22rpx;
  color: #AAAAAA;
}

.duration-value {
  font-size: 22rpx;
  color: #555555;
  font-weight: 500;
}

.record-remark {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #FAF7F4;
  border-radius: 12rpx;
}

.remark-label {
  display: block;
  font-size: 22rpx;
  color: #AAAAAA;
  margin-bottom: 6rpx;
}

.remark-value {
  display: block;
  font-size: 24rpx;
  color: #555555;
  line-height: 1.5;
}

.record-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F0ED;
  display: flex;
  justify-content: flex-end;
}

.btn-cancel {
  font-size: 24rpx;
  color: #E74C3C;
  padding: 10rpx 24rpx;
  border: 1rpx solid #E74C3C;
  border-radius: 20rpx;
  text-align: center;
}

/* 定金状态标签 */
.deposit-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 12rpx;
}

.deposit-tag-pending {
  background: #FFF3CD;
  color: #7A5C00;
}

.deposit-tag-paid {
  background: #D4EDDA;
  color: #155724;
}

.deposit-tag-forfeited {
  background: #F8D7DA;
  color: #721C24;
}

.deposit-tag-refunded {
  background: #E2E8F0;
  color: #4A5568;
}

/* 查看详情提示 */
.record-detail-hint {
  font-size: 22rpx;
  color: #BBBBBB;
  text-align: right;
  margin-top: 12rpx;
}

/* 待付款状态 */
.status-unpaid {
  background: #FFF3CD;
  color: #7A5C00;
}

/* 报价链状态 */
.status-quote-pending  { background: #FFF3CD; color: #7A5C00; }
.status-quote-quoted   { background: #D4E6FF; color: #1A5276; }
.status-quote-rejected { background: #F0F0F0; color: #999999; }

.quote-resubmit-hint { color: #C8847A; }

.record-card-quote { border-left: 4rpx solid #C8847A; }

.record-chain-badge {
  display: inline-block;
  font-size: 18rpx;
  background: #FDE8E6;
  color: #C8847A;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.record-quote-note {
  display: block;
  font-size: 22rpx;
  color: #888888;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #AAAAAA;
}

/* 会员权益 */
.benefits-current-card {
  margin: 0 30rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.25);
  position: relative;
  overflow: hidden;
}

.benefits-current-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  margin-bottom: 24rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.benefit-check {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  flex-shrink: 0;
}

.benefit-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.benefits-discount-badge {
  position: absolute;
  top: 28rpx;
  right: 32rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.25);
}

.tier-table-card {
  margin: 0 30rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(200, 132, 122, 0.06);
}

.tier-table-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2C;
  padding: 24rpx 32rpx 16rpx;
}

.tier-table-row {
  display: flex;
  align-items: center;
  padding: 18rpx 32rpx;
  border-top: 1rpx solid #F5F0ED;
}

.tier-table-header {
  background: #FAF7F4;
  border-top: none;
}

.tier-table-header .tc-name,
.tier-table-header .tc-spend,
.tier-table-header .tc-discount {
  font-size: 22rpx;
  color: #AAAAAA;
  font-weight: 500;
}

.tier-row-active {
  background: #FDE8E6;
}

.tier-row-active .tc-name,
.tier-row-active .tc-spend,
.tier-row-active .tc-discount {
  color: #C8847A;
  font-weight: 600;
}

.tc-name {
  flex: 2;
  font-size: 26rpx;
  color: #2C2C2C;
}

.tc-spend {
  flex: 2;
  font-size: 26rpx;
  color: #555555;
  text-align: center;
}

.tc-discount {
  flex: 1;
  font-size: 26rpx;
  color: #555555;
  text-align: right;
}

.upgrade-hint-card {
  margin: 0 30rpx 32rpx;
  background: #FFF8E7;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  border-left: 6rpx solid #F5A623;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.upgrade-hint-text {
  flex: 1;
  font-size: 24rpx;
  color: #7A5C00;
  line-height: 1.5;
}

.upgrade-recharge-btn {
  background: #C9A76B;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* 积分明细 */
.points-log-card {
  margin: 0 30rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(200, 132, 122, 0.05);
}

.log-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.log-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.log-earn { background: #6BBF6B; }
.log-spend { background: #C8847A; }

.log-desc {
  display: block;
  font-size: 28rpx;
  color: #2C2C2C;
  margin-bottom: 4rpx;
}

.log-time {
  display: block;
  font-size: 22rpx;
  color: #AAAAAA;
}

.log-points {
  font-size: 32rpx;
  font-weight: 700;
}

.log-pts-earn { color: #6BBF6B; }
.log-pts-spend { color: #C8847A; }

/* 消费历史底部弹窗 */
.spend-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.spend-sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 env(safe-area-inset-bottom);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.spend-handle {
  width: 72rpx;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 8rpx;
  margin: 20rpx auto 0;
  flex-shrink: 0;
}

.spend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx 20rpx;
  border-bottom: 1rpx solid #F5F0ED;
  flex-shrink: 0;
}

.spend-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C2C2C;
}

.spend-total {
  font-size: 26rpx;
  color: #C8847A;
  font-weight: 600;
}

.spend-list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0 24rpx;
}

.spend-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid #F5F0ED;
}

.spend-item:last-child {
  border-bottom: none;
}

.spend-item-left {
  flex: 1;
  margin-right: 20rpx;
}

.spend-item-service {
  display: block;
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.spend-item-meta {
  display: block;
  font-size: 22rpx;
  color: #AAAAAA;
}

.spend-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 6rpx;
}

.spend-item-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #C8847A;
}

.spend-item-method {
  font-size: 20rpx;
  color: #AAAAAA;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
}

.spend-empty {
  text-align: center;
  color: #AAAAAA;
  font-size: 28rpx;
  padding: 60rpx 0;
}
.topup-amount { color: #27AE60 !important; }
.spend-pagination { display: flex; align-items: center; justify-content: center; gap: 32rpx; padding: 24rpx 0 8rpx; }
.spend-page-nav { font-size: 28rpx; color: #C8847A; padding: 8rpx 24rpx; border: 1rpx solid #C8847A; border-radius: 32rpx; }
.spend-page-disabled { color: #CCC; border-color: #CCC; pointer-events: none; }
.spend-page-label { font-size: 26rpx; color: #888; }

/* 空状态补充 */
.empty-sub {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 再做一次按钮 */
.rebook-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.rebook-btn {
  font-size: 24rpx;
  color: #C8847A;
  background: #FDE8E6;
  padding: 10rpx 28rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 我的报价 */
.quote-card {
  margin: 0 30rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(200,132,122,0.06);
}

.quote-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F5F0ED;
}

.quote-thumb-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: #F5F0ED;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.quote-card-body { flex: 1; min-width: 0; }

.quote-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.quote-preferred {
  font-size: 26rpx;
  color: #2C2C2C;
  font-weight: 500;
}

.quote-status-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.quote-sts-pending  { background: #FFF3CD; color: #7A5C00; }
.quote-sts-quoted   { background: #D4E6FF; color: #1A5276; }
.quote-sts-confirmed { background: #D4EDDA; color: #155724; }
.quote-sts-rejected { background: #F0F0F0; color: #888888; }

.quote-price {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #C8847A;
  margin-bottom: 6rpx;
}

.quote-tech {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 4rpx;
}

.quote-note {
  display: block;
  font-size: 23rpx;
  color: #AAAAAA;
  line-height: 1.5;
}

.quote-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  flex-shrink: 0;
  align-self: center;
}
