/* 报价详情页 */

.qd-loading { padding: 80rpx; text-align: center; }
.qd-loading-text { font-size: 28rpx; color: #AAAAAA; }

/* 状态横幅 */
.qd-status-bar {
  margin: 24rpx 30rpx;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.qd-s-pending  { background: #FFF8E7; }
.qd-s-quoted   { background: linear-gradient(135deg, #FDE8E6, #FEF3F2); }
.qd-s-confirmed { background: #E6F0E5; }
.qd-s-rejected { background: #F5F5F5; }

.qd-s-icon { font-size: 44rpx; flex-shrink: 0; }
.qd-s-info { flex: 1; }
.qd-s-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2C2C2C;
  margin-bottom: 6rpx;
}
.qd-s-sub { display: block; font-size: 22rpx; color: #888888; line-height: 1.5; }

/* 图片滚动 */
.qd-img-scroll { padding: 0 30rpx; margin-bottom: 8rpx; }
.qd-img-list { display: flex; gap: 16rpx; padding-bottom: 8rpx; }
.qd-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  display: block;
}

/* 信息卡 */
.qd-card {
  margin: 0 30rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(200,132,122,0.06);
}
.qd-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F0ED;
}
.qd-row:last-child { border-bottom: none; }
.qd-label { font-size: 26rpx; color: #888888; flex-shrink: 0; width: 120rpx; }
.qd-val { font-size: 26rpx; color: #2C2C2C; text-align: right; }
.qd-val-remark { text-align: left; flex: 1; padding-left: 16rpx; line-height: 1.6; }
.qd-val-tags { display: flex; gap: 12rpx; flex-wrap: wrap; justify-content: flex-end; }
.qd-tag {
  background: #FDE8E6; color: #C8847A; font-size: 22rpx;
  padding: 6rpx 16rpx; border-radius: 14rpx;
}

/* 报价卡 */
.qd-quote-card {
  margin: 0 30rpx 24rpx;
  background: linear-gradient(135deg, #FDE8E6, #FEF3F2);
  border-radius: 20rpx;
  padding: 32rpx;
}
.qd-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(200,132,122,0.2);
}
.qd-price-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.qd-price-label    { font-size: 26rpx; color: #888888; }
.qd-price-duration { font-size: 24rpx; color: #C8847A; font-weight: 500; }
.qd-price { font-size: 52rpx; font-weight: 700; color: #C8847A; }
.qd-quote-rows { display: flex; flex-direction: column; gap: 16rpx; }
.qd-qrow { display: flex; justify-content: space-between; }
.qd-ql { font-size: 26rpx; color: #888888; }
.qd-qv { font-size: 26rpx; color: #2C2C2C; font-weight: 500; }
.qd-note { color: #666666; font-weight: 400; text-align: right; max-width: 300rpx; line-height: 1.5; }

/* 操作按钮 */
.qd-actions {
  padding: 0 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.qd-btn-book {
  background: linear-gradient(135deg, #C8847A, #E8A89E);
  color: #FFFFFF;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  padding: 32rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(200,132,122,0.35);
}
.qd-btn-reject {
  background: #F5F0ED;
  color: #888888;
  text-align: center;
  font-size: 28rpx;
  padding: 24rpx 0;
  border-radius: 50rpx;
}
.qd-confirmed-tip {
  margin: 0 30rpx 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: #6BAD6B;
  padding: 28rpx;
  background: #F0FAF0;
  border-radius: 16rpx;
}

.qd-rejected-section {
  margin: 0 30rpx 40rpx;
  padding: 32rpx;
  background: #F8F8F8;
  border-radius: 20rpx;
  text-align: center;
}
.qd-rejected-tip {
  display: block;
  font-size: 26rpx;
  color: #888888;
  line-height: 1.6;
  margin-bottom: 28rpx;
}
.qd-btn-resubmit {
  background: linear-gradient(135deg, #C8847A, #E8A89E);
  color: #FFFFFF;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(200,132,122,0.35);
}
