/* 图片预约页 */

.q-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 30rpx 32rpx;
  gap: 12rpx;
}
.q-hero-icon { font-size: 64rpx; }
.q-hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2C2C;
}
.q-hero-sub {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}

.req-star { color: #E74C3C; font-size: 28rpx; }

/* 图片上传网格 */
.q-img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 30rpx 8rpx;
}
.q-img-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}
.q-img-thumb { width: 160rpx; height: 160rpx; display: block; }
.q-img-del {
  position: absolute;
  top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.q-img-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #E0D8D5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FAFAFA;
}
.q-img-add-icon { font-size: 48rpx; color: #C8847A; line-height: 1; }
.q-img-add-hint { font-size: 22rpx; color: #BBBBBB; }
.q-img-tip {
  display: block;
  font-size: 22rpx;
  color: #AAAAAA;
  padding: 4rpx 30rpx 0;
}

/* 通用卡片 */
.q-card {
  margin: 0 30rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(200,132,122,0.06);
}
.q-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 88rpx;
}
.q-row-wrap { flex-wrap: wrap; gap: 16rpx; }
.q-label {
  font-size: 28rpx;
  color: #2C2C2C;
  flex-shrink: 0;
  width: 120rpx;
}
.q-val { font-size: 28rpx; color: #C8847A; }
.q-placeholder { color: #BBBBBB; }
.q-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C2C2C;
  text-align: right;
}
.q-divider { height: 1rpx; background: #F5F0ED; margin: 0 32rpx; }
.q-textarea {
  width: 100%;
  min-height: 140rpx;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.7;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
}

/* 时间段芯片 */
.q-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}
.q-chip {
  font-size: 22rpx;
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  background: #F5F0ED;
  color: #666666;
  border: 2rpx solid transparent;
}
.q-chip-active {
  background: #FDE8E6;
  color: #C8847A;
  border-color: #C8847A;
}

/* 勾选项 */
.q-check-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx 32rpx;
}
.q-check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  border: 2rpx solid #E0D8D5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}
.q-checked {
  background: #C8847A;
  border-color: #C8847A;
}
.q-check-tick { font-size: 26rpx; color: #FFFFFF; font-weight: 700; }
.q-check-info { flex: 1; }
.q-check-label { display: block; font-size: 28rpx; color: #2C2C2C; margin-bottom: 6rpx; }
.q-check-sub { display: block; font-size: 22rpx; color: #AAAAAA; line-height: 1.5; }

/* 提交区 */
.q-submit-wrap {
  padding: 32rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}
.q-btn-disabled {
  opacity: 0.5;
}
.q-submit-note {
  font-size: 22rpx;
  color: #AAAAAA;
  text-align: center;
}
