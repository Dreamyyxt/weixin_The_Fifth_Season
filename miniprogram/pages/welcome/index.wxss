/* ===== 欢迎页 ===== */

/* ===== 花瓣飘落 ===== */
.petals-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 3;
  overflow: hidden;
}

.petal {
  position: absolute;
  top: -40rpx;
  animation-name: petalFall;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  animation-fill-mode: both;
}

/* 三种花瓣形态 */
.petal-t0 {
  border-radius: 60% 0 60% 0;
  background: rgba(255, 170, 160, 0.78);
}
.petal-t1 {
  border-radius: 50% 50% 0 0;
  background: rgba(230, 140, 128, 0.7);
}
.petal-t2 {
  border-radius: 80% 0 80% 0;
  background: rgba(255, 210, 200, 0.72);
}

@keyframes petalFall {
  0%   { transform: translateY(-60rpx) translateX(0) rotate(0deg);     opacity: 0; }
  12%  { opacity: 0.85; }
  48%  { transform: translateY(44vh) translateX(36rpx) rotate(190deg); opacity: 0.8; }
  86%  { opacity: 0.65; }
  100% { transform: translateY(112vh) translateX(-18rpx) rotate(380deg); opacity: 0; }
}


.page {
  min-height: 100vh;
  background: linear-gradient(170deg, #1C0E08 0%, #2E1510 55%, #3D1F16 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 64rpx 100rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 背景光晕 */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.bg-glow-top {
  width: 700rpx;
  height: 700rpx;
  top: -280rpx;
  right: -240rpx;
  background: radial-gradient(circle, rgba(200, 132, 122, 0.22) 0%, transparent 65%);
}

.bg-glow-bottom {
  width: 560rpx;
  height: 560rpx;
  bottom: -160rpx;
  left: -200rpx;
  background: radial-gradient(circle, rgba(160, 90, 70, 0.18) 0%, transparent 65%);
}

/* ===== 动画基础状态 ===== */
.brand-section,
.user-section,
.member-card,
.btn-section {
  opacity: 0;
  transform: translateY(36rpx);
  transition: opacity 0.55s ease, transform 0.55s ease;
}

.avatar-section {
  opacity: 0;
  transform: scale(0.75);
  transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.brand-section.show,
.user-section.show,
.member-card.show,
.btn-section.show {
  opacity: 1;
  transform: translateY(0);
}

.avatar-section.show {
  opacity: 1;
  transform: scale(1);
}

/* ===== 品牌区 ===== */
.brand-section {
  text-align: center;
  margin-bottom: 64rpx;
}

.brand-logo-img {
  width: 420rpx;
  height: 154rpx;
  margin-bottom: 10rpx;
  filter: brightness(1) saturate(50%) invert(80%) sepia(28%) saturate(550%) hue-rotate(315deg) brightness(100%) drop-shadow(0 0 16rpx rgba(200, 132, 122, 0.5));
}

.brand-en {
  display: block;
  font-size: 20rpx;
  color: rgba(245, 232, 224, 0.4);
  letter-spacing: 8rpx;
  margin-bottom: 32rpx;
}

.brand-divider {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #C8847A, transparent);
  margin: 0 auto;
}

/* ===== 头像区 ===== */
.avatar-section {
  margin-bottom: 44rpx;
}

.avatar-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  padding: 5rpx;
  background: linear-gradient(135deg, #C8847A 0%, #E8C4BC 50%, #C8847A 100%);
  box-shadow: 0 0 70rpx rgba(200, 132, 122, 0.55), 0 0 20rpx rgba(200, 132, 122, 0.3);
  overflow: hidden;
}

.avatar-img {
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  border: 4rpx solid #1C0E08;
  display: block;
}

.avatar-fallback {
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: #3D1F16;
  border: 4rpx solid #1C0E08;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-fallback-text {
  font-size: 72rpx;
  color: #C8847A;
  font-weight: 300;
}

/* ===== 欢迎语 + 昵称 ===== */
.user-section {
  text-align: center;
  margin-bottom: 56rpx;
}

.welcome-greeting {
  display: block;
  font-size: 26rpx;
  color: rgba(245, 232, 224, 0.5);
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
}

.user-nickname {
  display: block;
  font-size: 56rpx;
  color: #F5E8E0;
  font-weight: 400;
  letter-spacing: 4rpx;
}

/* ===== 会员卡 ===== */
.member-card {
  width: 100%;
  margin-bottom: 72rpx;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
}

.member-card-body {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(200, 132, 122, 0.28);
  border-radius: 24rpx;
  padding: 32rpx 44rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.member-card-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.05) 50%, transparent 60%);
  border-radius: 24rpx;
  pointer-events: none;
}

.member-label {
  display: block;
  font-size: 22rpx;
  color: rgba(245, 232, 224, 0.45);
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.member-no {
  display: block;
  font-size: 34rpx;
  color: #C8847A;
  font-weight: 500;
  letter-spacing: 5rpx;
}

.member-level-badge {
  font-size: 24rpx;
  color: #C8847A;
  background: rgba(200, 132, 122, 0.12);
  border: 1rpx solid rgba(200, 132, 122, 0.35);
  border-radius: 40rpx;
  padding: 10rpx 28rpx;
}

/* ===== 进入按钮 ===== */
.btn-section {
  width: 100%;
}

.enter-btn {
  background: linear-gradient(135deg, #C8847A 0%, #D4968C 100%);
  border-radius: 88rpx;
  padding: 36rpx 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 48rpx rgba(200, 132, 122, 0.45);
}

.enter-btn-text {
  font-size: 34rpx;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  font-weight: 500;
  margin-right: 8rpx;
}

.enter-btn-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1;
  margin-top: -4rpx;
}
