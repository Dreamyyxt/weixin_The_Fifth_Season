/* 帖子详情页样式 */

.container {
  background: #FAF7F4;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 作者信息 */
.post-author {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 30rpx 24rpx;
  background: #FFFFFF;
}

.author-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F7D9D7, #F2BEB8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-emoji {
  font-size: 44rpx;
}

.author-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2C;
}

.level-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.level-gold   { background: #FDF3E3; color: #C9A76B; }
.level-silver { background: #F0F0F0; color: #888888; }
.level-normal { background: #F0F0F0; color: #AAAAAA; }

.post-time {
  font-size: 22rpx;
  color: #AAAAAA;
}

/* 正文 */
.post-body {
  padding: 24rpx 30rpx;
  background: #FFFFFF;
}

.post-content {
  font-size: 30rpx;
  color: #2C2C2C;
  line-height: 1.8;
}

/* 图片 */
.post-images {
  display: flex;
  gap: 6rpx;
  padding: 0 30rpx 24rpx;
  background: #FFFFFF;
}

.post-img {
  flex: 1;
  height: 280rpx;
  border-radius: 16rpx;
}

.img-pink     { background: linear-gradient(135deg, #F9D7D4, #F2B5B0); }
.img-coral    { background: linear-gradient(135deg, #F9D5C0, #F4B898); }
.img-lavender { background: linear-gradient(135deg, #E2D5F2, #CDB8E8); }
.img-gold     { background: linear-gradient(135deg, #F2E6C8, #E8CFA0); }
.img-green    { background: linear-gradient(135deg, #D5E8D3, #BAD5B7); }
.img-white    { background: linear-gradient(135deg, #F5F0ED, #EDE5E0); }

/* 标签 */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 30rpx 24rpx;
  background: #FFFFFF;
}

.post-tag {
  font-size: 22rpx;
  color: #C8847A;
  background: #FDE8E6;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
}

/* 互动操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  padding: 28rpx 0;
  border-top: 1rpx solid #F5F0ED;
  border-bottom: 1rpx solid #F5F0ED;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: none;
  border: none;
  padding: 0;
  line-height: normal;
}

.action-item::after {
  border: none;
}

.action-emoji {
  font-size: 36rpx;
}

.action-num {
  font-size: 26rpx;
  color: #888888;
  min-height: 32rpx;
}

.action-label {
  font-size: 22rpx;
  color: #AAAAAA;
}

.action-liked .action-num {
  color: #C8847A;
}

.action-share {
  background: none;
  border: none;
}

.divider-line {
  height: 16rpx;
  background: #F5F0ED;
}

/* 评论区 */
.comments-section {
  background: #FFFFFF;
  padding: 32rpx 30rpx;
}

.comments-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2C;
  margin-bottom: 24rpx;
}

.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 60rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #BBBBBB;
}

/* 单条评论 */
.comment-item {
  display: flex;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F5F3;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F7D9D7, #F2BEB8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.comment-avatar-emoji {
  font-size: 36rpx;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.comment-user {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C2C2C;
}

.comment-time {
  font-size: 22rpx;
  color: #AAAAAA;
}

.comment-text {
  display: block;
  font-size: 28rpx;
  color: #2C2C2C;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.comment-footer {
  display: flex;
  justify-content: flex-end;
}

.comment-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #AAAAAA;
}

.cmt-liked {
  color: #C8847A;
}

.cmt-like-num {
  font-size: 22rpx;
}

/* 底部输入框（固定） */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #F0EBE8;
  box-shadow: 0 -4rpx 16rpx rgba(200, 132, 122, 0.08);
}

.input-wrap {
  flex: 1;
  background: #F5F0ED;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
}

.comment-input {
  width: 100%;
  font-size: 28rpx;
  color: #2C2C2C;
}

.send-btn {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.send-active {
  background: linear-gradient(135deg, #C8847A, #E8A89E);
  color: #FFFFFF;
}

.send-disabled {
  background: #F0EDED;
  color: #CCCCCC;
}
