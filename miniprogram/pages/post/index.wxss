/* 发帖页样式 */

.points-hint {
  margin: 24rpx 30rpx;
  background: linear-gradient(135deg, #FDF3E3, #F8E8C0);
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hint-icon {
  color: #C9A76B;
  font-size: 24rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #888888;
}

.hint-pts {
  color: #C9A76B;
  font-weight: 600;
}

.section-card {
  margin: 0 30rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(200, 132, 122, 0.06);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2C;
  margin-bottom: 20rpx;
}

.count-label {
  font-size: 22rpx;
  color: #AAAAAA;
  font-weight: 400;
  margin-left: 12rpx;
}

/* 图片网格 */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.img-item {
  position: relative;
  aspect-ratio: 1;
}

.img-preview {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.img-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #2C2C2C;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.img-add {
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #F5DDD9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FEF8F7;
}

.img-add-icon {
  font-size: 48rpx;
  color: #E8A89E;
  line-height: 1;
}

.img-add-text {
  font-size: 22rpx;
  color: #C8847A;
}

/* 内容区 */
.content-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #2C2C2C;
  line-height: 1.7;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 12rpx;
}

/* 标签选择 */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  font-size: 26rpx;
  color: #888888;
  background: #F5F0ED;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.tag-selected {
  background: #FDE8E6;
  color: #C8847A;
  font-weight: 500;
}

/* 提交 */
.submit-area {
  padding: 0 30rpx 60rpx;
}

.submit-btn {
  width: 100%;
  padding: 28rpx 0;
  font-size: 32rpx;
}
